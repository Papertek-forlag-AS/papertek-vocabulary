{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://papertek.no/schemas/vocabulary/adjective.schema.json",
  "title": "Adjective Schema",
  "description": "Schema for adjective entries with comparison forms and declension",
  "type": "object",
  "additionalProperties": {
    "$ref": "#/$defs/adjectiveEntry"
  },
  "$defs": {
    "adjectiveEntry": {
      "type": "object",
      "properties": {
        "word": {
          "type": "string",
          "description": "Base/positive form of the adjective"
        },
        "audio": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "const": "adj"
        },
        "intro": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+$"
        },
        "translations": {
          "$ref": "core-word.schema.json#/$defs/translations"
        },
        "synonyms": {
          "type": "array",
          "items": { "type": "string" }
        },
        "translation_synonyms": {
          "$ref": "core-word.schema.json#/$defs/translationSynonyms"
        },
        "explanations": {
          "$ref": "core-word.schema.json#/$defs/explanations"
        },
        "comparison": {
          "$ref": "#/$defs/comparison"
        },
        "declension": {
          "$ref": "#/$defs/declension"
        }
      },
      "required": []
    },
    "comparison": {
      "type": "object",
      "description": "Comparison forms (positiv, komparativ, superlativ)",
      "properties": {
        "positiv": {
          "type": "string",
          "description": "Positive/base form"
        },
        "komparativ": {
          "$ref": "#/$defs/comparisonForm"
        },
        "superlativ": {
          "$ref": "#/$defs/comparisonForm"
        }
      },
      "additionalProperties": false
    },
    "comparisonForm": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "properties": {
            "form": { "type": "string" },
            "intro": {
              "type": "string",
              "pattern": "^[0-9]+\\.[0-9]+$"
            },
            "feature": { "type": "string" }
          },
          "required": ["form"]
        }
      ]
    },
    "genderNumber": {
      "type": "object",
      "properties": {
        "maskulin": { "type": "string" },
        "feminin":  { "type": "string" },
        "neutrum":  { "type": "string" },
        "plural":   { "type": "string" }
      },
      "additionalProperties": false
    },
    "caseBlock": {
      "type": "object",
      "properties": {
        "nominativ":  { "$ref": "#/$defs/genderNumber" },
        "akkusativ":  { "$ref": "#/$defs/genderNumber" },
        "dativ":      { "$ref": "#/$defs/genderNumber" },
        "genitiv":    { "$ref": "#/$defs/genderNumber" }
      },
      "additionalProperties": false
    },
    "articleBlock": {
      "type": "object",
      "properties": {
        "stark":    { "$ref": "#/$defs/caseBlock" },
        "schwach":  { "$ref": "#/$defs/caseBlock" },
        "gemischt": { "$ref": "#/$defs/caseBlock" }
      },
      "additionalProperties": false
    },
    "superlativBlock": {
      "type": "object",
      "properties": {
        "schwach": { "$ref": "#/$defs/caseBlock" }
      },
      "additionalProperties": false
    },
    "declension": {
      "type": "object",
      "properties": {
        "positiv":    { "$ref": "#/$defs/articleBlock" },
        "komparativ": { "$ref": "#/$defs/articleBlock" },
        "superlativ": { "$ref": "#/$defs/superlativBlock" }
      },
      "additionalProperties": false
    }
  }
}
