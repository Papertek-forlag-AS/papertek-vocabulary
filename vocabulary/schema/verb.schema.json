{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://papertek.no/schemas/vocabulary/verb.schema.json",
  "title": "Verb Schema",
  "description": "Schema for verb entries with conjugation tables",
  "type": "object",
  "additionalProperties": {
    "$ref": "#/$defs/verbEntry"
  },
  "$defs": {
    "verbEntry": {
      "type": "object",
      "properties": {
        "word": {
          "type": "string",
          "description": "Infinitive form of the verb"
        },
        "audio": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "description": "Verb classification",
          "enum": ["strong", "weak", "modal", "reflexive", "separable", "auxiliary", "regular", "irregular", "verbphrase"]
        },
        "tags": {
          "type": "array",
          "description": "Secondary verb traits not captured by primary type (e.g., type: separable, tags: [irregular])",
          "items": {
            "type": "string",
            "enum": ["regular", "irregular", "modal", "separable", "reflexive", "inseparable"]
          }
        },
        "intro": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+$"
        },
        "translations": {
          "$ref": "core-word.schema.json#/$defs/translations"
        },
        "synonyms": {
          "type": "array",
          "items": { "type": "string" }
        },
        "translation_synonyms": {
          "$ref": "core-word.schema.json#/$defs/translationSynonyms"
        },
        "explanations": {
          "$ref": "core-word.schema.json#/$defs/explanations"
        },
        "conjugations": {
          "$ref": "#/$defs/conjugations"
        },
        "inseparable": {
          "type": "boolean",
          "description": "True for verbs with inseparable prefixes (be-, er-, ge-, ent-, emp-, miss-, ver-, zer-) that never add ge- in participle"
        }
      },
      "required": ["translations"]
    },
    "conjugations": {
      "type": "object",
      "description": "Conjugation tables keyed by tense name",
      "additionalProperties": {
        "$ref": "#/$defs/tenseConjugation"
      }
    },
    "tenseConjugation": {
      "type": "object",
      "properties": {
        "intro": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+$",
          "description": "Lesson where this tense is introduced"
        },
        "feature": {
          "type": "string",
          "description": "Grammar feature flag (e.g., 'grammar_presens')"
        },
        "former": {
          "type": "object",
          "description": "Person/pronoun to conjugated form mapping",
          "additionalProperties": {
            "type": "string"
          }
        },
        "auxiliary": {
          "type": "string",
          "description": "Auxiliary verb for Perfektum: haben, sein, or both",
          "enum": ["haben", "sein", "both"]
        },
        "participle": {
          "type": "string",
          "description": "Past participle form (e.g., gemacht, gegangen)"
        },
        "auxiliary_note": {
          "type": "object",
          "description": "Object keyed by auxiliary explaining when each is used (dual-auxiliary verbs only)",
          "additionalProperties": { "type": "string" }
        },
        "dual_auxiliary": {
          "type": "boolean",
          "description": "True for verbs that use both haben and sein depending on usage"
        },
        "modal_note": {
          "type": "string",
          "description": "Explains Ersatzinfinitiv behavior (modal verbs only)"
        }
      },
      "required": ["former"]
    }
  }
}
