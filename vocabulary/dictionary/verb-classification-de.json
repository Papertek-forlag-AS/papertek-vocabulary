  "_metadata": {
    "description": "Per-tense verb classification for German. Maps verb IDs to their grammar class in each tense, and flags separable verbs with their prefix. Used by exercises to filter verbs correctly (e.g., 'practice strong verbs in Präteritum', 'practice separable verbs').",
    "classes": {
      "weak": "Regular conjugation pattern (e.g., spielen → spielte → hat gespielt)",
      "strong": "Irregular with vowel change (e.g., fahren → fuhr → ist gefahren)",
      "mixed": "Mixed pattern: weak endings + vowel change (e.g., bringen → brachte → hat gebracht)",
      "modal": "Modal verb with special conjugation"
    },
    "separableField": "When present, contains the separable prefix string (e.g., 'auf', 'an', 'ein'). Verbs with this field split in present tense: 'aufstehen' → 'ich stehe auf'.",
    "notes": "Verbs marked 'strong' in presens have stem-vowel change in 2nd/3rd person singular (du isst, er isst). Verbs marked 'weak' in presens follow regular pattern even if they are strong in past tenses.",
    "updatedAt": "2026-02-13"
  },

