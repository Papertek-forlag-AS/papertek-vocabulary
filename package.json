{
  "name": "papertek-vocabulary",
  "version": "1.0.0",
  "description": "Papertek Vocabulary API — vocabulary data and API for language learning apps",
  "license": "MIT",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Papertek-forlag-AS/papertek-vocabulary"
  },
  "homepage": "https://vocab.papertek.no",
  "bugs": {
    "url": "https://github.com/Papertek-forlag-AS/papertek-vocabulary/issues"
  },
  "keywords": [
    "vocabulary",
    "language-learning",
    "german",
    "spanish",
    "french",
    "norwegian",
    "api",
    "education"
  ],
  "scripts": {
    "dev": "vercel dev",
    "build:search-index": "node scripts/build-search-index.js",
    "validate:nouns": "node scripts/validate-nouns.js",
    "validate:verbs": "node scripts/validate-verbs.js",
    "validate:adjectives": "node scripts/validate-adjectives.js",
    "validate:all": "npm run validate:nouns && npm run validate:verbs && npm run validate:adjectives && npm run verify:integration",
    "verify:integration": "node scripts/verify-integration.js",
    "validate:migration": "node scripts/validate-migration.js",
    "generate:nb-lexicon": "node scripts/generate-nb-lexicon.js",
    "generate:links": "node scripts/generate-links.js",
    "generate:lexicon": "npm run generate:nb-lexicon && npm run generate:links",
    "enrich:nb": "node scripts/enrich-nb-lexicon.js",
    "build:lexicon": "npm run generate:lexicon && npm run enrich:nb",
    "generate:source-lexicon": "node scripts/generate-source-lexicon.js",
    "build:lexicon-search-index": "node scripts/build-lexicon-search-index.js",
    "generate:en-lexicon": "node scripts/generate-en-lexicon.js",
    "generate:en-links": "node scripts/generate-en-links.js",
    "validate:lexicon": "node scripts/validate-lexicon.js",
    "build:lexicon-all": "npm run build:lexicon && npm run generate:en-lexicon && npm run generate:en-links && npm run generate:source-lexicon && npm run build:lexicon-search-index"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1"
  }
}
